# ─── JWT (gunakan string random panjang, bukan token GitHub) ─────────────────
JWT_SECRET=saturn-dashboard-super-secret-key-change-this

# ─── GitHub (Classic PAT dengan scope: repo) ─────────────────────────────────
# Buat baru di: https://github.com/settings/tokens → Classic Token → centang 'repo'
GITHUB_TOKEN=ghp_GANTI_DENGAN_TOKEN_BARU_YANG_VALID

# ─── GitHub repo info ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_OWNER=luminarydearx
NEXT_PUBLIC_GITHUB_REPO=SaturnDashboard---Personal-Dashboard
NEXT_PUBLIC_AUTOGEN_PROJECT_PATH=project/AutoGen

# ─── Base URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Vercel API (untuk Redeploy AutoGen) ─────────────────────────────────────
# VERCEL_TOKEN: buat di https://vercel.com/account/tokens
# VERCEL_AUTOGEN_PROJECT_ID: Vercel dashboard → auto-generator-app → Settings → General → Project ID
VERCEL_TOKEN=vcp_38WHk8H5IBgDtYSWzmuunUcyXMXjN0nhIuu81PtUXPUenGvyCH3a2sS3
VERCEL_AUTOGEN_PROJECT_ID=prj_ntRN2KRqAzVN9M3Wnptd1hOEwT5W
{
  "name": "saturn-dashboard",
  "version": "4.5.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron electron/main.js",
    "electron:build": "next build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.6.5",
    "jose": "^5.9.6",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.4.0",
    "sharp": "^0.33.5",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.2"
  },
  "build": {
    "appId": "com.saturndashboard.app",
    "productName": "SaturnDashboard",
    "directories": { "output": "dist-electron" },
    "files": [
      ".next/**/*",
      "public/**/*",
      "data/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.js"
    ],
    "mac":   { "icon": "public/logo.png", "target": "dmg" },
    "win":   { "icon": "public/logo.png", "target": "nsis" },
    "linux": { "icon": "public/logo.png", "target": "AppImage" }
  },
  "main": "electron/main.js"
}

{
  "name": "saturn-dashboard",
  "version": "4.4.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron electron/main.js",
    "electron:build": "next build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "zip": "powershell -command \"Get-ChildItem -Path . -Recurse | Where-Object { $_.FullName -notmatch 'node_modules|.next|.git' } | Compress-Archive -DestinationPath saturn-dashboard.zip -Force\""
  },
  "dependencies": {
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "jose": "^5.2.4",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "axios": "^1.6.8",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.1.9",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.1.0",
    "sharp": "^0.33.3",
    "next-pwa": "^5.6.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.0.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.saturndashboard.app",
    "productName": "SaturnDashboard",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      ".next/**/*",
      "public/**/*",
      "data/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.js"
    ],
    "mac": {
      "icon": "public/logo.png",
      "target": "dmg"
    },
    "win": {
      "icon": "public/logo.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "public/logo.png",
      "target": "AppImage"
    }
  },
  "main": "electron/main.js"
}
